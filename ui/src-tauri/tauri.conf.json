{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Quill",
  "version": "0.2.0",
  "identifier": "app.quill.writing",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "label": "mini",
        "title": "Quill",
        "url": "index.html",
        "width": 380,
        "height": 560,
        "minWidth": 380,
        "minHeight": 200,
        "decorations": false,
        "alwaysOnTop": true,
        "transparent": true,
        "resizable": false,
        "visible": false,
        "skipTaskbar": true,
        "center": true,
        "shadow": false,
        "focus": true
      },
      {
        "label": "full",
        "title": "Quill — Full Panel",
        "url": "index.html",
        "width": 600,
        "height": 740,
        "minWidth": 560,
        "minHeight": 500,
        "decorations": false,
        "alwaysOnTop": true,
        "transparent": true,
        "resizable": true,
        "visible": false,
        "skipTaskbar": false,
        "center": true,
        "shadow": true
      }
    ],
    "security": {
      "csp": null
    },
    "trayIcon": {
      "iconPath": "icons/icon.png",
      "iconAsTemplate": true,
      "menuOnLeftClick": false,
      "title": "Quill"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.ico"
    ],
    "resources": []
  }
}
